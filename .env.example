# Copy this file to .env and fill in your values.
# Never commit your actual .env file with real secrets.

# GitHub personal access token (required for private repos or to avoid rate limits)
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API key (required for AI summary and commit-message commands)
OPENAI_API_KEY=sk-your_key_here

# Custom OpenAI-compatible API base URL (optional – for Ollama, Azure, Groq, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Default repository for the review command (optional, avoids repeating --repo)
# GITREVIEW_REPO=owner/repo

# LLM model used by the conversational agent (default: gpt-4o)
# AGENT_MODEL=gpt-4o
